  "keyFeatures": [
    "Type-safe dependency injection with singleton and transient scopes",
    "Lightweight event emitter with async support",
    "Extensible architecture with plugins and extensions",
    "Built-in caching system with pluggable storage backends",
    "React Router integration with Vite",
    "Multi-platform deployment (Node.js, Vercel, Netlify)",
    "Database integration with Drizzle ORM",
    "Structured logging with LogTape",
    "HTTP server with Hono framework",
    "TypeScript-first with full type safety"
  ],
  "publicApiSurface": [
    "createApp - Main application factory function",
    "App - Application class with lifecycle management",
    "Extension - Plugin system for extending functionality",
    "Container - Dependency injection container",
    "inject - Function for resolving dependencies",
    "Provider - Interface for registering services",
    "Emitter - Event emitter class",
    "Cacher - Cache manager with async operations",
    "defineDevConfig - Development configuration helper",
    "createHttpServer - HTTP server factory",
    "Logger - Logging service",
    "Database providers - Integration with Drizzle ORM"
  ]
